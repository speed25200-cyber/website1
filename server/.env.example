# Copiez en .env (ou définissez ces variables dans votre hébergeur)
FC_PORT=8787
# Jeton Bearer protégeant l'écriture de contenu et la lecture des leads.
# Générez-en un fort, ex. : openssl rand -hex 32
FC_API_TOKEN=changez-moi-avec-un-jeton-fort
# CORS : origine de l'app / du site (ou * en dev)
FC_ALLOW_ORIGIN=*
# Optionnel : racine du site et dossier de données
# FC_ROOT=..
# FC_DATA_DIR=./data

# --- Worker Cronos (cronos-worker.js) : traitement autonome des demandes ---
# API à interroger (si le worker tourne ailleurs que sur le backend)
# FC_API_URL=http://localhost:8787
# Identifiant de l'agent (visible dans lead.history / assignee)
# CRONOS_AGENT=cronos-local
# Endpoint LLM local compatible OpenAI (Ollama, LM Studio, llama.cpp-server…)
# CRONOS_LLM_URL=http://localhost:11434/v1
# CRONOS_LLM_MODEL=llama3.1
# CRONOS_LLM_KEY=
# Secondes entre deux passes de la boucle autonome
# CRONOS_INTERVAL=30

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.fri-consult.ch/content/schema/lead.schema.json",
  "title": "Demande (lead) — payload structuré émis par les formulaires du site",
  "description": "Objet JSON envoyé au leadWebhook (et, à plat, à FormSubmit). Contrat stable pour l'app iOS et Cronos.",
  "type": "object",
  "required": ["type", "source", "createdAt", "contact"],
  "properties": {
    "schema": { "type": "string", "const": "fri-consult/lead@1", "description": "Version du contrat." },
    "type": { "type": "string", "enum": ["quote", "contact"], "description": "quote = demande d'offre ; contact = message." },
    "source": { "type": "string", "description": "Page d'origine (ex. demande-offre.html)." },
    "createdAt": { "type": "string", "format": "date-time", "description": "Horodatage ISO 8601 (UTC)." },
    "locale": { "type": "string", "default": "fr-CH" },
    "insurances": { "type": "array", "items": { "type": "string" }, "description": "IDs/titres des domaines d'assurance demandés (quote)." },
    "profile": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "description": "Particulier / Indépendant / Entreprise / Frontalier." },
        "canton": { "type": "string" },
        "birthdate": { "type": "string" },
        "callback": { "type": "string", "description": "Moment de rappel souhaité." }
      }
    },
    "contact": {
      "type": "object",
      "required": ["email"],
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" }
      }
    },
    "subject": { "type": "string" },
    "message": { "type": "string" },
    "consent": { "type": "boolean", "description": "Consentement RGPD/nLPD explicite." }
  }
}
